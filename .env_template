# Copia este archivo a .env y rellena los valores:  cp .env_template .env

# Token de Hugging Face con acceso a pyannote/speaker-diarization-3.1.
# Necesario para la diarización del transcriptor.
# Obtén el tuyo en: https://huggingface.co/settings/tokens
HF_TOKEN=

# Clave de API de Anthropic. Necesaria para el chatbot de análisis (analyzer).
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=
